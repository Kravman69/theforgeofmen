<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Forge of Men</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <style>
        body { font-family: 'Georgia', serif; }
        .forge-bg { background: linear-gradient(to bottom, #1f2937, #111827); }
    </style>
</head>
<body class="bg-gray-950 text-gray-100">
    <!-- Navigation -->
    <nav class="bg-black border-b border-amber-800 p-4">
        <div class="max-w-6xl mx-auto flex justify-between items-center">
            <div class="text-2xl font-bold text-amber-500">THE FORGE OF MEN</div>
            <div class="space-x-6">
                <a href="#pillars" class="hover:text-amber-500">Pillars</a>
                <a href="#reads" class="hover:text-amber-500">Forge Reads</a>
                <a href="#events" class="hover:text-amber-500">Gatherings</a>
                <a href="#join" class="hover:text-amber-500">Join</a>
            </div>
        </div>
    </nav>

    <!-- Hero -->
    <header class="forge-bg py-24 text-center">
        <h1 class="text-5xl font-bold mb-4">Forging Spirit, Mind, & Body in Christ</h1>
        <p class="max-w-xl mx-auto text-xl text-gray-300">A brotherhood for men over 21. Real connection. Real growth. No hate—just strength.</p>
        <a href="#join" class="mt-8 inline-block bg-amber-600 hover:bg-amber-500 px-8 py-4 rounded font-semibold">Join the Forge</a>
    </header>

    <!-- Pillars -->
    <section id="pillars" class="max-w-6xl mx-auto py-16 px-4">
        <h2 class="text-3xl font-bold text-center mb-12">The 3 Pillars</h2>
        <div class="grid md:grid-cols-3 gap-8">
            <!-- Pillar cards here - Spiritual, Mental, Physical -->
        </div>
    </section>

    <!-- Forge Reads -->
    <section id="reads" class="bg-gray-900 py-16">
        <div class="max-w-6xl mx-auto px-4">
            <h2 class="text-3xl font-bold text-center mb-12">Forge Reads</h2>
            <!-- Book list with summaries -->
            <div class="grid gap-8">
                <!-- A Purpose Driven Life card, etc. -->
            </div>
        </div>
    </section>

    <!-- More sections... -->
    <footer class="bg-black py-8 text-center text-sm">
        The Forge of Men © 2026 | theforgeofmen.org
    </footer>
</body>
</html>
